---
import '../styles/global.css';
import { LANGS, type Lang } from '../data/tournament';
import { UI } from '../i18n/ui';
import { homeUrl, calUrl, groupsUrl } from '../lib/site';
import TopTicker from '../components/TopTicker.astro';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  path?: string; // sub-path after the locale, e.g. '' | 'calendario/' | 'grupos/a/'
  active?: 'home' | 'calendar' | 'groups' | 'teams' | 'scorers' | 'qualified' | 'bracket' | 'simulator';
  ogImage?: string;
  jsonLd?: object | object[];
  breadcrumbs?: { name: string; url: string }[];
  noindex?: boolean; // p.ej. partido KO con el cruce aún sin resolver: vivo pero no indexable
  canonical?: string;
}
const { lang, title, description, path = '', active, ogImage, jsonLd, breadcrumbs, noindex = false, canonical: canonicalOverride } = Astro.props;
const ui = UI[lang];
const site = (Astro.site?.href ?? 'https://mundialsimulador.com/').replace(/\/$/, '');
const canonical = canonicalOverride ?? `${site}/${lang}/${path}`;
const ogImg = ogImage ?? `${site}/og.png`;
const OG_LOCALE: Record<Lang, string> = { es: 'es_ES', en: 'en_US', pt: 'pt_BR' };
const orgJsonLd = [
  { '@context': 'https://schema.org', '@type': 'Organization', name: ui.brand.title, url: `${site}/${lang}/`, logo: `${site}/og.png` },
  { '@context': 'https://schema.org', '@type': 'WebSite', name: ui.brand.title, url: `${site}/`, inLanguage: ui.htmlLang },
];
const crumbJsonLd = breadcrumbs && breadcrumbs.length
  ? {
      '@context': 'https://schema.org', '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((c, i) => ({ '@type': 'ListItem', position: i + 1, name: c.name, item: c.url.startsWith('http') ? c.url : `${site}${c.url}` })),
    }
  : null;
const navLinks = [
  { key: 'simulator', href: `/${lang}/simulador/`, label: lang === 'en' ? 'Simulator' : 'Simulador' },
  { key: 'groups', href: groupsUrl(lang), label: ui.nav.groups },
  { key: 'qualified', href: `/${lang}/clasificados/`, label: lang === 'en' ? 'Qualified' : lang === 'pt' ? 'Classificados' : 'Clasificados' },
  { key: 'bracket', href: `/${lang}/cuadro/`, label: lang === 'en' ? 'Bracket' : lang === 'pt' ? 'Chave' : 'Cuadro' },
  { key: 'calendar', href: calUrl(lang), label: ui.nav.calendar },
  { key: 'scorers', href: `/${lang}/goleadores/`, label: lang === 'en' ? 'Scorers' : lang === 'pt' ? 'Artilheiros' : 'Goleadores' },
];
---
<!doctype html>
<html lang={ui.htmlLang}>
<head>
  <meta charset="utf-8" />
  <script is:inline>var h=document.documentElement;h.classList.add('js');try{if(matchMedia('(prefers-reduced-motion: reduce)').matches)h.classList.add('rm');}catch(e){}</script>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, follow" />}
  <link rel="canonical" href={canonical} />
  {LANGS.map((l) => (
    <link rel="alternate" hreflang={UI[l].htmlLang} href={`${site}/${l}/${path}`} />
  ))}
  <link rel="alternate" hreflang="x-default" href={`${site}/es/${path}`} />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={ui.brand.title} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImg} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content={OG_LOCALE[lang]} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImg} />

  <meta name="theme-color" content="#0d0f14" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@600;700;800&display=swap" />
  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}
  <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
  {crumbJsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(crumbJsonLd)} />
  )}
</head>
<body>
  <TopTicker lang={lang} />
  <div class="wrap">
    <header class="site-head">
      <a class="logo" href={homeUrl(lang)}>
        <span class="crest">🏆</span>
        <span><b>{ui.brand.title}</b><span>{ui.brand.tagline}</span></span>
      </a>
      <nav class="site-nav">
        {navLinks.map((n) => (
          <a href={n.href} class={active === n.key ? 'active' : ''}>{n.label}</a>
        ))}
        <span class="langsw">
          {LANGS.map((l) => (
            <a href={`/${l}/${path}`} class={l === lang ? 'on' : ''} hreflang={UI[l].htmlLang}>{l}</a>
          ))}
        </span>
      </nav>
    </header>

    <slot />

    <footer class="site-foot">
      <div class="flinks">
        <a href={homeUrl(lang)}>{ui.nav.home}</a>
        <a href={`/${lang}/simulador/`}>{lang === 'en' ? 'Simulator' : 'Simulador'}</a>
        <a href={groupsUrl(lang)}>{ui.nav.groups}</a>
        <a href={`/${lang}/clasificados/`}>{lang === 'en' ? 'Qualified' : lang === 'pt' ? 'Classificados' : 'Clasificados'}</a>
        <a href={`/${lang}/cuadro/`}>{lang === 'en' ? 'Bracket' : lang === 'pt' ? 'Chave' : 'Cuadro'}</a>
        <a href={`/${lang}/partidos-de-hoy/`}>{lang === 'en' ? "Today's matches" : lang === 'pt' ? 'Jogos de hoje' : 'Partidos de hoy'}</a>
        <a href={calUrl(lang)}>{ui.nav.calendar}</a>
        <a href={`/${lang}/goleadores/`}>{lang === 'en' ? 'Scorers' : lang === 'pt' ? 'Artilheiros' : 'Goleadores'}</a>
        <a href={`/${lang}/formato/`}>{lang === 'en' ? 'Format' : 'Formato'}</a>
        <a href={`/${lang}/sedes/`}>{lang === 'en' ? 'Stadiums' : lang === 'pt' ? 'Estádios' : 'Estadios'}</a>
        <a href={`/${lang}/palmares/`}>{lang === 'en' ? 'Honours' : 'Palmarés'}</a>
        <a href={`/${lang}/sobre/`}>{lang === 'en' ? 'About' : 'Sobre'}</a>
      </div>
      {ui.footer.disclaimer}
    </footer>
  </div>
  <script is:inline>
    (function(){var h=document.documentElement;if(h.classList.contains('rm')||!('IntersectionObserver' in window))return;var sel='.page-head,.hero,.section-h,.cal-grid,.tile,.team-card,.qcard,.vcard,.trophy-card,.hub-link,.scen-card,.group,.tw,.sim-promo,.bk-card,.qa';var els=[].slice.call(document.querySelectorAll(sel));if(!els.length)return;var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});},{threshold:0.06,rootMargin:'0px 0px -40px 0px'});els.forEach(function(el){io.observe(el);});setTimeout(function(){els.forEach(function(el){el.classList.add('in');});},1600);})();
  </script>
</body>
</html>
