---
import type { Lang } from '../data/tournament';
import { UI } from '../i18n/ui';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const ui = UI[lang];
---
<section class="sim" data-lang={lang}>
  <div class="sim-actions">
    <button class="btn primary" id="btnShare">{ui.sim.share}</button>
    <button class="btn ghost" id="btnRandom">{ui.sim.random2}</button>
    <button class="btn ghost" id="btnReset">{ui.sim.reset}</button>
  </div>
  <div class="tabs">
    <button class="tab active" id="tabGroups"><span>📋</span><span class="txt">{ui.sim.tabGroups}</span><span class="pill" id="grPill">0/12</span></button>
    <button class="tab" id="tabKO"><span>🔥</span><span class="txt">{ui.sim.tabKnockout}</span><span class="lock" id="koLock">🔒</span></button>
  </div>
  <div class="progress-bar"><i id="progFill"></i></div>

  <div id="view-groups"><div id="groupArea"></div></div>

  <div id="view-knockout" class="hidden">
    <div class="champion" id="championBox"></div>
    <div class="bracket-scroll"><div class="bracket" id="bracket"></div></div>
    <p class="ko-note">{ui.sim.koNote}</p>
  </div>

  <div class="modal-bg" id="modalBg"><div class="modal"><button class="modal-x" id="modalX">✕</button><div id="modalBody"></div></div></div>
  <div class="toast" id="toast"></div>
</section>

<script>
  import '../scripts/simulator';
</script>
