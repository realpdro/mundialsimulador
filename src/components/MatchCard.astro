---
import { teamName, flagUrl, type Lang } from '../data/tournament';
import { spainTime, overnightNote, teamUrl } from '../lib/site';
import { UI } from '../i18n/ui';

interface Result { status: string; utc?: string; scores?: Record<string, number>; live?: boolean; }
interface Props {
  lang: Lang;
  label: string;
  ko?: boolean;
  koSpain: string | null;
  koLocal?: string | null;
  a: string | null;
  b: string | null;
  stadium?: string | null;
  city?: string | null;
  result?: Result | null;
  previewHref?: string | null;
  aLabel?: string | null; // procedencia cuando a es null (KO sin resolver): "1.º A", "Ganador P74"
  bLabel?: string | null;
  previewText?: string | null;
}
const { lang, label, ko = false, koSpain, koLocal = null, a, b, stadium = null, city = null, result = null, previewHref = null, aLabel = null, bLabel = null, previewText = null } = Astro.props;
const ui = UI[lang];
const FIN = { es: 'Final', en: 'Full-time', pt: 'Encerrado' }[lang];
const LIVE = { es: '🔴 EN JUEGO', en: '🔴 LIVE', pt: '🔴 AO VIVO' }[lang];
const PREV = { es: 'Previa y resultado →', en: 'Preview & result →', pt: 'Prévia e resultado →' }[lang];
const r = result;
const sa = r?.scores && a ? r.scores[a] : null;
const sb = r?.scores && b ? r.scores[b] : null;
const hasScore = sa !== null && sa !== undefined && sb !== null && sb !== undefined;
const winA = hasScore && (sa as number) > (sb as number);
const winB = hasScore && (sb as number) > (sa as number);
const note = overnightNote(koSpain, lang);
---
<div class={hasScore || r?.live ? 'cal-match played' : 'cal-match'} data-pair={a && b ? [a, b].sort().join('-') : undefined} data-a={a ?? undefined} data-b={b ?? undefined}>
  <div class="cm-top">
    <span class={ko ? 'gtag ko' : 'gtag'}>{label}</span>
    {r?.live
      ? <span class="cm-stat live">{LIVE}</span>
      : hasScore
        ? <span class="cm-stat fin">{FIN}</span>
        : <span class="cm-time">{spainTime(koSpain)}h {koLocal && <small>({koLocal} {ui.common.localTime})</small>}</span>}
  </div>
  <div class="cm-teams">
    {a
      ? <a class={winA ? 'cm-team win' : 'cm-team'} href={teamUrl(lang, a)}><img class="flag" width="23" height="16" loading="lazy" src={flagUrl(a)} alt="" /><span class="tname">{teamName(a, lang)}</span>{hasScore && <b class="cm-score">{sa}</b>}</a>
      : <div class="cm-team"><span class="tname" style={aLabel ? 'color:var(--muted2);font-weight:600' : ''}>{aLabel ?? ui.common.tbd}</span></div>}
    {b
      ? <a class={winB ? 'cm-team win' : 'cm-team'} href={teamUrl(lang, b)}><img class="flag" width="23" height="16" loading="lazy" src={flagUrl(b)} alt="" /><span class="tname">{teamName(b, lang)}</span>{hasScore && <b class="cm-score">{sb}</b>}</a>
      : <div class="cm-team"><span class="tname" style={bLabel ? 'color:var(--muted2);font-weight:600' : ''}>{bLabel ?? ui.common.tbd}</span></div>}
  </div>
  {(stadium || city) && <div class="cm-venue">📍 {stadium}{stadium && city ? ', ' : ''}{city}</div>}
  {note && !hasScore && !r?.live && <div class="cm-note">{note}</div>}
  {previewHref && <a href={previewHref} style="display:block;text-align:center;margin-top:9px;padding-top:9px;border-top:1px solid var(--line);font-size:.78rem;font-weight:700;color:var(--accent)">{previewText ?? PREV}</a>}
</div>
