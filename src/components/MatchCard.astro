---
import { teamName, flagUrl, teamColor, type Lang } from '../data/tournament';
import { spainTime, teamUrl } from '../lib/site';
import { UI } from '../i18n/ui';

interface Result { status: string; utc?: string; scores?: Record<string, number>; live?: boolean; }
interface Props {
  lang: Lang;
  label?: string;
  ko?: boolean;
  koSpain: string | null;
  koLocal?: string | null;
  a: string | null;
  b: string | null;
  stadium?: string | null;
  city?: string | null;
  result?: Result | null;
  previewHref?: string | null;
  aLabel?: string | null;
  bLabel?: string | null;
  previewText?: string | null;
}
const { lang, label = '', koSpain, a, b, result = null, previewHref = null, aLabel = null, bLabel = null } = Astro.props;
const ui = UI[lang];
const r = result;
const sa = r?.scores && a ? r.scores[a] : null;
const sb = r?.scores && b ? r.scores[b] : null;
const hasScore = sa !== null && sa !== undefined && sb !== null && sb !== undefined;
const live = !!r?.live;
const winA = hasScore && (sa as number) > (sb as number);
const winB = hasScore && (sb as number) > (sa as number);

const MONTHS = {
  es: ['', 'ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'],
  en: ['', 'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
  pt: ['', 'jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez'],
}[lang];
const d10 = (koSpain || '').slice(0, 10);
const shortDate = d10 ? `${parseInt(d10.slice(8, 10), 10)} ${MONTHS[parseInt(d10.slice(5, 7), 10)]}` : '';
const comp = label && label.length <= 14 ? label : shortDate;
const fin = { es: 'Final', en: 'Final', pt: 'Final' }[lang];
const status = hasScore ? fin : spainTime(koSpain);
const pair = a && b ? [a, b].slice().sort().join('-') : undefined;
const nA = a ? teamName(a, lang) : (aLabel ?? ui.common.tbd);
const nB = b ? teamName(b, lang) : (bLabel ?? ui.common.tbd);
---
<div class={`am${hasScore || live ? ' played' : ''}`} style={`--ca:${teamColor(a)};--cb:${teamColor(b)}`} data-pair={pair} data-a={a ?? undefined} data-b={b ?? undefined}>
  {previewHref && <a class="am-link" href={previewHref} aria-label={`${nA} - ${nB}`}></a>}
  <div class={`am-side home${winB ? ' lose' : ''}`}>
    {a
      ? <a class="am-crest" href={teamUrl(lang, a)}><img class="flag" width="32" height="24" loading="lazy" src={flagUrl(a)} alt="" /></a>
      : <span class="am-crest dot"></span>}
    <span class="am-name">{nA}</span>
  </div>
  <b class={`am-score${winA ? ' win' : ''}${winB ? ' lose' : ''}`} data-side="a">{hasScore ? sa : ''}</b>
  <div class="am-mid">
    {comp && <span class="am-comp">{comp}</span>}
    <span class={`am-st${live ? ' live' : ''}${hasScore ? ' fin' : ''}`}>{live ? '•' : status}</span>
  </div>
  <b class={`am-score${winB ? ' win' : ''}${winA ? ' lose' : ''}`} data-side="b">{hasScore ? sb : ''}</b>
  <div class={`am-side away${winA ? ' lose' : ''}`}>
    <span class="am-name">{nB}</span>
    {b
      ? <a class="am-crest" href={teamUrl(lang, b)}><img class="flag" width="32" height="24" loading="lazy" src={flagUrl(b)} alt="" /></a>
      : <span class="am-crest dot"></span>}
  </div>
</div>
