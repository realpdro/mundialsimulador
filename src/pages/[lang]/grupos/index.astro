---
import Base from '../../../layouts/Base.astro';
import { LANGS, type Lang, GROUPS, LETTERS, teamName, flagUrl } from '../../../data/tournament';
import { UI } from '../../../i18n/ui';
import { groupUrl, teamUrl } from '../../../lib/site';
import RESULTS from '../../../data/results.json';
import { realStandings } from '../../../lib/standings';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}
const lang = Astro.params.lang as Lang;
const ui = UI[lang];
const BYPAIR = (RESULTS as any).byPair as Record<string, any>;
---
<Base lang={lang} title={ui.meta.groupsTitle} description={ui.meta.groupsDesc} path="grupos/" active="groups">
  <div class="page-head">
    <h1>{ui.groups.title}</h1>
    <p>{ui.groups.intro}</p>
  </div>
  <div class="tile-grid">
    {LETTERS.map((L) => {
      const st = realStandings(L, BYPAIR);
      return (
      <div class="tile">
        <a class="tl-head" href={groupUrl(lang, L)}><span class="tag">{L}</span> {ui.common.group} {L}</a>
        {st.order.map((s, idx) => (
          <a class="tl-team" href={teamUrl(lang, s.code)}>
            <span class={st.played > 0 ? `tl-pos p${idx + 1}` : 'tl-pos'}>{idx + 1}</span>
            <img class="flag" width="23" height="16" loading="lazy" src={flagUrl(s.code)} alt="" />
            <span class="tl-name">{teamName(s.code, lang)}</span>
            {st.played > 0 && <b class="tl-pts">{s.pts}</b>}
          </a>
        ))}
      </div>
      );
    })}
  </div>
</Base>
