---
import Base from '../../layouts/Base.astro';
import { LANGS, type Lang, GROUPS, LETTERS, SCHEDULE, ES_NAME_TO_CODE, teamName, teamColor, flagUrl } from '../../data/tournament';
import { UI } from '../../i18n/ui';
import { calUrl, groupsUrl, groupUrl, teamUrl, roundName, roundUrl, matchUrl, koMatchUrl, formatDay } from '../../lib/site';
import { resolveBracket } from '../../lib/bracket';
import { phaseInfo, isPlayed } from '../../lib/phase';
import RESULTS from '../../data/results.json';
import MatchCard from '../../components/MatchCard.astro';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}
const lang = Astro.params.lang as Lang;
const ui = UI[lang];
const byPair = ((RESULTS as any).byPair || {}) as Record<string, any>;
const bracket = resolveBracket(byPair, lang);
const koByNo: Record<number, any> = Object.fromEntries(bracket.rounds.flatMap((r) => r.matches.map((m) => [m.m, { ...m, round: r.round }])));
const { groupStageDone } = phaseInfo(byPair);
const koPlayed = (m: any) => { const a = m?.a?.code, b = m?.b?.code; return a && b ? isPlayed(byPair[[a, b].slice().sort().join('-')]) : false; };
const koRounds = bracket.rounds.map((r) => { const total = r.matches.length; const done = r.matches.filter(koPlayed).length; return { round: r.round, name: roundName(lang, r.round), total, done }; });
let currentRoundIdx = koRounds.findIndex((r) => r.done < r.total);
if (currentRoundIdx < 0) currentRoundIdx = Math.max(0, koRounds.length - 1);
const todayMadrid = new Intl.DateTimeFormat('en-CA', { timeZone: 'Europe/Madrid', year: 'numeric', month: '2-digit', day: '2-digit' }).format(new Date());

interface Row { koSpain: string | null; koLocal: string | null; label: string; ko: boolean; a: string | null; b: string | null; aLabel: string | null; bLabel: string | null; result: any; href: string | null; day: string; }
const rows: Row[] = [];
SCHEDULE.groupStage.forEach((m) => {
  const a = ES_NAME_TO_CODE[m.teamA] ?? null, b = ES_NAME_TO_CODE[m.teamB] ?? null;
  rows.push({ koSpain: m.koSpain, koLocal: m.koLocal, label: `${ui.common.group} ${m.group}`, ko: false, a, b, aLabel: null, bLabel: null, result: a && b ? byPair[[a, b].sort().join('-')] ?? null : null, href: matchUrl(lang, m), day: (m.koSpain || m.date).slice(0, 10) });
});
SCHEDULE.knockout.forEach((m) => {
  const bm = koByNo[m.matchNo]; const a = bm?.a.code ?? null, b = bm?.b.code ?? null;
  rows.push({ koSpain: m.koSpain, koLocal: m.koLocal, label: roundName(lang, m.round), ko: true, a, b, aLabel: a ? null : (bm?.a.label ?? null), bLabel: b ? null : (bm?.b.label ?? null), result: a && b ? byPair[[a, b].sort().join('-')] ?? null : null, href: koMatchUrl(lang, m.matchNo), day: (m.koSpain || m.date).slice(0, 10) });
});
rows.sort((x, y) => (x.koSpain || x.day).localeCompare(y.koSpain || y.day));
const isToday = rows.some((r) => r.day === todayMadrid);

// --- Segmented: Ayer / Hoy / Próximos ---
const yMad = (() => { const [Y, M, D] = todayMadrid.split('-').map(Number); const d = new Date(Date.UTC(Y, M - 1, D - 1)); return `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, '0')}-${String(d.getUTCDate()).padStart(2, '0')}`; })();
const yesterdayRows = rows.filter((r) => r.day === yMad);
const todayRows = rows.filter((r) => r.day === todayMadrid);
const futureDays = [...new Set(rows.filter((r) => r.day > todayMadrid).map((r) => r.day))].slice(0, 2);
const upcomingRows = rows.filter((r) => futureDays.includes(r.day));
// --- Partido destacado (HERO): en vivo > próximo de hoy > próximo en general > último jugado ---
const playable = rows.filter((r) => r.a && r.b);
const nowMadT = `${todayMadrid}T${new Intl.DateTimeFormat('en-GB', { timeZone: 'Europe/Madrid', hour: '2-digit', minute: '2-digit', hour12: false }).format(new Date())}`;
const liveRow = playable.find((r) => r.result?.live);
const upcomingToday = playable.find((r) => r.day === todayMadrid && !r.result?.scores && (r.koSpain || '') >= nowMadT)
  ?? playable.find((r) => r.day === todayMadrid && !r.result?.scores)
  ?? playable.find((r) => r.day === todayMadrid);
const nextOverall = playable.find((r) => r.day > todayMadrid);
const lastPlayed = [...playable].reverse().find((r) => r.result?.scores);
const featured = liveRow ?? upcomingToday ?? nextOverall ?? lastPlayed ?? null;

// Listas del segmentado, excluyendo el destacado para no duplicarlo.
const SEG = {
  es: { yest: 'Ayer', today: 'Hoy', next: 'Próximos', empty: 'No hay partidos.' },
  en: { yest: 'Yesterday', today: 'Today', next: 'Upcoming', empty: 'No matches.' },
  pt: { yest: 'Ontem', today: 'Hoje', next: 'Próximos', empty: 'Sem jogos.' },
}[lang];
const ydList = yesterdayRows.filter((r) => r !== featured);
const tdList = todayRows.filter((r) => r !== featured);
const upList = upcomingRows.filter((r) => r !== featured);
const defaultSeg = tdList.length ? 'today' : (upList.length ? 'next' : 'yest');
const segPanels = [
  { id: 'yest', label: SEG.yest, rows: ydList },
  { id: 'today', label: SEG.today, rows: tdList },
  { id: 'next', label: SEG.next, rows: upList },
];

const FB_MONTH = { es: ['', 'ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'], en: ['', 'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'], pt: ['', 'jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez'] }[lang];
function heroData(r: Row | null) {
  if (!r || !r.a || !r.b) return null;
  const d10 = (r.koSpain || '').slice(0, 10);
  const sa = r.result?.scores ? r.result.scores[r.a] as number : null;
  const sb = r.result?.scores ? r.result.scores[r.b] as number : null;
  const hasScore = sa != null && sb != null;
  return {
    pair: [r.a, r.b].slice().sort().join('-'),
    a: r.a, b: r.b, sa, sb, hasScore, live: !!r.result?.live,
    time: r.koSpain ? r.koSpain.slice(11, 16) : '',
    date: d10 ? `${parseInt(d10.slice(8, 10), 10)} ${FB_MONTH[parseInt(d10.slice(5, 7), 10)]}` : '',
    href: r.href, label: r.label,
  };
}
const HERO = heroData(featured);
const heroTag = { es: { live: 'EN JUEGO', next: 'Próximo partido' }, en: { live: 'LIVE', next: 'Up next' }, pt: { live: 'AO VIVO', next: 'A seguir' } }[lang];

const C = {
  es: { title: 'Resultados del Mundial 2026 en directo · marcadores y clasificación', desc: 'Marcadores en vivo del Mundial 2026: partidos de hoy, resultados, clasificación de los grupos, cuadro de eliminatorias y máximos goleadores. Todo en directo y se actualiza solo.', h1: 'Mundial 2026 en directo', intro: 'Resultados, partidos de hoy, clasificación y cuadro de eliminatorias — en vivo y se actualiza solo.', seeCal: 'Calendario completo', groupsH: 'Grupos del Mundial 2026', simH: '¿Y tú, cómo crees que acaba?', simSub: 'Predice todos los partidos, monta el cuadro y descubre tu campeón.', simCta: 'Abrir el simulador' },
  en: { title: '2026 World Cup live scores · results and standings', desc: 'Live scores of the 2026 World Cup: today\'s matches, results, group standings, knockout bracket and top scorers. All live and updating automatically.', h1: '2026 World Cup live', intro: 'Results, today\'s matches, standings and the knockout bracket — live and updating automatically.', seeCal: 'Full schedule', groupsH: '2026 World Cup groups', simH: 'How do you think it ends?', simSub: 'Predict every match, build the bracket and find your champion.', simCta: 'Open the simulator' },
  pt: { title: 'Resultados da Copa 2026 ao vivo · placares e classificação', desc: 'Placares ao vivo da Copa 2026: jogos de hoje, resultados, classificação dos grupos, chaveamento do mata-mata e artilheiros. Tudo ao vivo e atualiza sozinho.', h1: 'Copa 2026 ao vivo', intro: 'Resultados, jogos de hoje, classificação e chaveamento — ao vivo e atualiza sozinho.', seeCal: 'Calendário completo', groupsH: 'Grupos da Copa 2026', simH: 'Como você acha que termina?', simSub: 'Preveja todos os jogos, monte o chaveamento e ache seu campeão.', simCta: 'Abrir o simulador' },
}[lang];

const HUB = {
  es: [['clasificados', 'Quién se clasifica', 'ti-checks'], ['cuadro', 'Cuadro de eliminatorias', 'ti-trophy'], ['goleadores', 'Máximos goleadores', 'ti-ball-football'], ['calendario', 'Calendario completo', 'ti-calendar']],
  en: [['clasificados', 'Who qualifies', 'ti-checks'], ['cuadro', 'Knockout bracket', 'ti-trophy'], ['goleadores', 'Top scorers', 'ti-ball-football'], ['calendario', 'Full schedule', 'ti-calendar']],
  pt: [['clasificados', 'Quem se classifica', 'ti-checks'], ['cuadro', 'Chaveamento', 'ti-trophy'], ['goleadores', 'Artilheiros', 'ti-ball-football'], ['calendario', 'Calendário completo', 'ti-calendar']],
}[lang];

const PH = {
  es: { koH: 'Eliminatorias', groupsDoneH: 'Clasificación final de los grupos', seeBracket: 'Ver el cuadro completo' },
  en: { koH: 'Knockouts', groupsDoneH: 'Final group standings', seeBracket: 'See the full bracket' },
  pt: { koH: 'Mata-mata', groupsDoneH: 'Classificação final dos grupos', seeBracket: 'Ver o chaveamento completo' },
}[lang];

const topScorers = ([...((RESULTS as any).scorers || [])] as any[]).sort((a, b) => b.goals - a.goals).slice(0, 5);
const SCO = { es: { title: 'Bota de Oro', all: 'Ver todos' }, en: { title: 'Golden Boot', all: 'See all' }, pt: { title: 'Chuteira de Ouro', all: 'Ver todos' } }[lang];
---
<Base lang={lang} title={C.title} description={C.desc} path="" active="home">
  <div class="home-head"><h1>{C.h1}</h1></div>

  {HERO && (
    <a
      class={`feat glass${HERO.hasScore ? ' played' : ''}`}
      href={HERO.href ?? undefined}
      style={`--ca:${teamColor(HERO.a)};--cb:${teamColor(HERO.b)}`}
      data-pair={HERO.pair} data-a={HERO.a} data-b={HERO.b}
      aria-label={`${teamName(HERO.a, lang)} - ${teamName(HERO.b, lang)}`}
    >
      <div class="feat-head">
        <span class={`feat-status${HERO.live ? ' live' : ''}`}>{HERO.live ? heroTag.live : (HERO.hasScore ? 'Final' : heroTag.next)}</span>
        <span class="feat-round">{HERO.label}</span>
      </div>
      <div class="feat-row">
        <div class="feat-team">
          <img class="flag" width="52" height="39" src={flagUrl(HERO.a)} alt="" />
          <span class="feat-name">{teamName(HERO.a, lang)}</span>
        </div>
        <div class="feat-mid">
          <div class="feat-kick"><span class="feat-time">{HERO.time}</span><span class="feat-date">{HERO.date}</span></div>
          <div class="feat-score"><b data-side="a">{HERO.hasScore ? HERO.sa : ''}</b><span>–</span><b data-side="b">{HERO.hasScore ? HERO.sb : ''}</b></div>
        </div>
        <div class="feat-team">
          <img class="flag" width="52" height="39" src={flagUrl(HERO.b)} alt="" />
          <span class="feat-name">{teamName(HERO.b, lang)}</span>
        </div>
      </div>
    </a>
  )}

  <div class="segwrap">
    <div class="seg-ctl" role="tablist" data-default={defaultSeg}>
      <span class="seg-pill" aria-hidden="true"></span>
      {segPanels.map((p) => (
        <button type="button" class="seg-btn" role="tab" data-seg={p.id} disabled={p.rows.length === 0}>
          {p.label}{p.rows.length > 0 && <i class="seg-n">{p.rows.length}</i>}
        </button>
      ))}
    </div>

    {segPanels.map((p) => (
      <div class="seg-panel" data-panel={p.id} hidden>
        {p.rows.length > 0 ? (
          <div class="cal-grid">
            {p.rows.map((m) => (
              <MatchCard lang={lang} label={m.label} ko={m.ko} koSpain={m.koSpain} koLocal={m.koLocal} a={m.a} b={m.b} aLabel={m.aLabel} bLabel={m.bLabel} result={m.result} previewHref={m.href} />
            ))}
          </div>
        ) : (
          <p class="seg-empty">{SEG.empty}</p>
        )}
      </div>
    ))}
  </div>

  {groupStageDone && (
    <section class="home-sec">
      <div class="sec-head"><h2>{PH.koH}</h2><a href={`/${lang}/cuadro/`}>{PH.seeBracket} →</a></div>
      <div class="ko-rounds">
        {koRounds.map((r, i) => (
          <a class={`ko-round${i === currentRoundIdx ? ' current' : ''}${r.done >= r.total ? ' done' : ''}`} href={roundUrl(lang, r.round)}>
            <b>{r.name}</b><span>{r.done >= r.total ? '✓' : `${r.done}/${r.total}`}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  {topScorers.length > 0 && (
    <section class="home-sec">
      <div class="sec-head"><h2>{SCO.title}</h2><a href={`/${lang}/goleadores/`}>{SCO.all} →</a></div>
      <div class="scorers glass">
        {topScorers.map((s, i) => (
          <a class="sc-row" href={teamUrl(lang, s.team)}>
            <span class="sc-rank">{i + 1}</span>
            <img class="sc-flag" width="24" height="17" loading="lazy" src={flagUrl(s.team)} alt="" />
            <span class="sc-name"><b>{s.name}</b><small>{teamName(s.team, lang)}</small></span>
            <span class="sc-goals">{s.goals}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="home-sec">
    <a class="sim-card glass" href={`/${lang}/simulador/`} data-astro-reload>
      <span class="sim-ico"><i class="ti ti-device-gamepad-2" aria-hidden="true"></i></span>
      <div><b>{C.simH}</b><span>{C.simSub}</span></div>
      <span class="btn primary">{C.simCta}</span>
    </a>
  </section>
</Base>

<style>
  .home-head { max-width:680px; margin:0 auto; padding:8px 2px 18px; }
  .home-head h1 { font-size:21px; font-weight:700; letter-spacing:-.02em; color:var(--txt); }
  .home-sec { max-width:680px; margin:0 auto; padding-top:28px; }
  .sec-head { display:flex; align-items:center; justify-content:space-between; margin:0 2px 12px; }
  .sec-head h2 { font-size:16px; font-weight:700; letter-spacing:-.01em; }
  .sec-head a { font-size:12.5px; color:var(--lime); font-weight:600; }
  .ko-rounds { display:flex; gap:8px; overflow-x:auto; scrollbar-width:none; padding-bottom:2px; }
  .ko-rounds::-webkit-scrollbar { display:none; }
  .ko-round { flex:1 0 auto; min-width:96px; display:flex; flex-direction:column; align-items:center; gap:5px; padding:13px 10px; border-radius:14px; color:var(--txt); background:var(--glass); border:1px solid var(--glass-line); }
  .ko-round b { font-size:13px; font-weight:700; white-space:nowrap; }
  .ko-round span { font-size:11px; color:var(--muted2); font-weight:800; font-variant-numeric:tabular-nums; }
  .ko-round.current { border-color:var(--lime); box-shadow:0 0 0 1px var(--lime),0 6px 18px rgba(199,242,76,.14); }
  .ko-round.current span { color:var(--lime); }
  .ko-round.done { opacity:.58; }
  .scorers { border-radius:16px; overflow:hidden; }
  .sc-row { display:flex; align-items:center; gap:11px; padding:10px 14px; color:var(--txt); }
  .sc-row + .sc-row { border-top:1px solid var(--glass-line); }
  .sc-row:hover { background:rgba(255,255,255,.03); }
  .sc-rank { width:16px; font-size:13px; font-weight:800; color:var(--muted2); text-align:center; flex:0 0 auto; }
  .sc-flag { width:24px; height:17px; border-radius:3px; box-shadow:0 0 0 1px rgba(255,255,255,.08); flex:0 0 auto; }
  .sc-name { flex:1; min-width:0; display:flex; flex-direction:column; }
  .sc-name b { font-size:14px; font-weight:600; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .sc-name small { font-size:11.5px; color:var(--muted2); }
  .sc-goals { font-size:16px; font-weight:800; color:var(--lime); font-variant-numeric:tabular-nums; flex:0 0 auto; }
  .sim-card { display:flex; align-items:center; gap:14px; border-radius:18px; padding:15px 16px; color:var(--txt); }
  .sim-ico { width:42px; height:42px; flex:0 0 auto; border-radius:12px; display:grid; place-items:center; background:rgba(199,242,76,.14); color:var(--lime); font-size:22px; }
  .sim-card > div { flex:1; min-width:0; display:flex; flex-direction:column; gap:2px; }
  .sim-card b { font-size:15px; font-weight:700; }
  .sim-card > div span { font-size:12.5px; color:var(--muted); }
  .sim-card .btn { white-space:nowrap; }
  @media (max-width:460px){ .sim-card .btn { display:none; } }

  /* ---------- Tarjeta destacada (featured, autocontenida) ---------- */
  .feat { position:relative; display:block; max-width:680px; margin:0 auto 22px; padding:15px 16px 18px; border-radius:22px; overflow:hidden; isolation:isolate; box-shadow:inset 0 1px 0 rgba(255,255,255,.12),var(--shadow); }
  .feat::before { content:""; position:absolute; inset:0; z-index:0; background:radial-gradient(130% 130% at 10% 4%,var(--ca) 0%,transparent 55%),radial-gradient(130% 130% at 90% 96%,var(--cb) 0%,transparent 55%); opacity:.3; }
  .feat > * { position:relative; z-index:1; }
  .feat:hover { transform:translateY(-2px); transition:transform .18s ease; }
  .feat-head { display:flex; flex-direction:column; align-items:center; gap:5px; margin-bottom:14px; }
  .feat-status { font-size:10.5px; font-weight:800; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); }
  .feat-status.live { display:inline-flex; align-items:center; gap:5px; color:#fff; background:var(--red); padding:3px 11px; border-radius:20px; box-shadow:0 0 14px rgba(255,90,77,.45); }
  .feat-status.live::before { content:""; width:6px; height:6px; border-radius:50%; background:#fff; animation:livepulse 1.4s infinite; }
  .feat-round { font-size:11px; color:var(--muted2); font-weight:600; }
  .feat-row { display:flex; align-items:flex-start; justify-content:space-between; gap:8px; }
  .feat-team { flex:1 1 0; min-width:0; display:flex; flex-direction:column; align-items:center; gap:9px; text-align:center; }
  .feat-team .flag { width:52px; height:39px; border-radius:7px; box-shadow:0 3px 12px rgba(0,0,0,.4),0 0 0 1px rgba(255,255,255,.14); }
  .feat-name { font-size:13.5px; font-weight:600; color:var(--txt); line-height:1.25; }
  .feat-mid { flex:0 0 auto; display:flex; flex-direction:column; align-items:center; justify-content:center; min-width:90px; padding-top:2px; }
  .feat-score { display:none; align-items:center; gap:9px; }
  .feat-score b { font-size:40px; font-weight:800; color:#fff; line-height:1; font-variant-numeric:tabular-nums; }
  .feat-score > span { font-size:24px; font-weight:300; color:rgba(255,255,255,.4); }
  .feat-kick { display:flex; flex-direction:column; align-items:center; }
  .feat-time { font-size:30px; font-weight:800; color:#fff; letter-spacing:-.02em; font-variant-numeric:tabular-nums; }
  .feat-date { font-size:11px; font-weight:600; color:rgba(255,255,255,.6); text-transform:uppercase; letter-spacing:.04em; }
  .feat.played .feat-kick { display:none; }
  .feat.played .feat-score { display:flex; }

  /* ---------- Segmented control (Ayer · Hoy · Próximos) ---------- */
  .segwrap { max-width:680px; margin:0 auto; }
  .seg-ctl { position:relative; display:flex; background:var(--card); border:1px solid var(--line); border-radius:13px; padding:4px; margin:0 auto 16px; max-width:360px; }
  .seg-btn { position:relative; z-index:1; flex:1; display:inline-flex; align-items:center; justify-content:center; gap:6px; font-size:13.5px; font-weight:700; padding:9px 6px; border-radius:9px; color:var(--muted); background:transparent; border:0; cursor:pointer; transition:color .2s ease; -webkit-tap-highlight-color:transparent; }
  .seg-btn[disabled] { opacity:.4; cursor:default; }
  .seg-btn.on { color:#04210f; }
  .seg-n { font-style:normal; font-size:10px; font-weight:800; min-width:16px; padding:1px 5px; border-radius:20px; background:rgba(255,255,255,.12); color:inherit; }
  .seg-btn.on .seg-n { background:rgba(0,0,0,.18); }
  .seg-pill { position:absolute; top:4px; bottom:4px; z-index:0; width:calc((100% - 8px) / 3); left:calc(4px + var(--i, 1) * (100% - 8px) / 3); border-radius:9px; background:linear-gradient(135deg,var(--green2),var(--green)); box-shadow:0 4px 14px rgba(48,209,88,.28); transition:left .28s cubic-bezier(.32,.72,0,1); }
  .seg-panel[hidden] { display:none; }
  .seg-empty { text-align:center; color:var(--muted2); font-size:13.5px; padding:24px 0; }
</style>

<script>
  // Segmented control: bundled (corre una vez) + re-init en cada astro:page-load (View Transitions).
  function initSeg() {
    const ctl = document.querySelector('.seg-ctl') as HTMLElement | null;
    if (!ctl) return;
    const btns = Array.from(ctl.querySelectorAll('.seg-btn')) as HTMLButtonElement[];
    const panels = Array.from(document.querySelectorAll('.seg-panel')) as HTMLElement[];
    const idx: Record<string, number> = { yest: 0, today: 1, next: 2 };
    function activate(id: string) {
      const btn = btns.find((b) => b.dataset.seg === id && !b.disabled);
      if (!btn) return;
      btns.forEach((b) => b.classList.toggle('on', b === btn));
      panels.forEach((p) => { p.hidden = p.dataset.panel !== id; });
      ctl!.style.setProperty('--i', String(idx[id] ?? 1));
    }
    btns.forEach((b) => b.addEventListener('click', () => { if (!b.disabled && b.dataset.seg) activate(b.dataset.seg); }));
    const def = ctl.dataset.default;
    const firstEnabled = btns.find((b) => !b.disabled);
    const start = (def && btns.find((b) => b.dataset.seg === def && !b.disabled)) ? def : firstEnabled?.dataset.seg;
    if (start) activate(start);
  }
  document.addEventListener('astro:page-load', initSeg);
</script>
