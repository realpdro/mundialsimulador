---
import Base from '../../layouts/Base.astro';
import Simulator from '../../components/Simulator.astro';
import { LANGS, type Lang, GROUPS, LETTERS, teamName } from '../../data/tournament';
import { UI } from '../../i18n/ui';
import { calUrl, groupsUrl, groupUrl, listTeams } from '../../lib/site';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}
const lang = Astro.params.lang as Lang;
const ui = UI[lang];
const site = (Astro.site?.href ?? 'https://mundialsimulador.com/').replace(/\/$/, '');
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: ui.brand.title,
  url: `${site}/${lang}/`,
  applicationCategory: 'SportsApplication',
  operatingSystem: 'Web',
  inLanguage: ui.htmlLang,
  description: ui.meta.homeDesc,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
};
const HUB = {
  es: { h: 'Sigue el Mundial 2026 en directo', items: [['clasificados', '✅ Quién se clasifica'], ['cuadro', '🏆 Cuadro de eliminatorias'], ['partidos-de-hoy', '📅 Partidos de hoy'], ['goleadores', '⚽ Máximos goleadores']] },
  en: { h: 'Follow the 2026 World Cup live', items: [['clasificados', '✅ Who qualifies'], ['cuadro', '🏆 Knockout bracket'], ['partidos-de-hoy', "📅 Today's matches"], ['goleadores', '⚽ Top scorers']] },
  pt: { h: 'Acompanhe a Copa 2026 ao vivo', items: [['clasificados', '✅ Quem se classifica'], ['cuadro', '🏆 Chaveamento'], ['partidos-de-hoy', '📅 Jogos de hoje'], ['goleadores', '⚽ Artilheiros']] },
}[lang];
---
<Base lang={lang} title={ui.meta.homeTitle} description={ui.meta.homeDesc} path="" active="home" jsonLd={jsonLd}>
  <section class="hero">
    <h1>{ui.hero.h1}</h1>
    <p>{ui.hero.sub}</p>
  </section>

  <Simulator lang={lang} />

  <section class="prose">
    <h2>{HUB.h}</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px">
      {HUB.items.map(([slug, label]) => (<a href={`/${lang}/${slug}/`} style="display:block;background:linear-gradient(180deg,var(--card),var(--bg2));border:1px solid var(--line);border-radius:12px;padding:14px 16px;color:inherit;font-weight:700">{label}</a>))}
    </div>
  </section>

  <section class="prose">
    <h2>{ui.groups.title}</h2>
    <p>{ui.groups.intro}</p>
    <div class="tile-grid">
      {LETTERS.map((L) => (
        <a class="tile" href={groupUrl(lang, L)}>
          <div class="tl-head"><span class="tag">{L}</span> {ui.common.group} {L}</div>
          {GROUPS[L].map((code) => (
            <div class="tl-team">{teamName(code, lang)}</div>
          ))}
        </a>
      ))}
    </div>

    <h2>{ui.cal.title}</h2>
    <p>{ui.cal.intro}</p>
    <p><a href={calUrl(lang)}>→ {ui.nav.calendar}</a> · <a href={groupsUrl(lang)}>{ui.nav.groups}</a></p>
  </section>
</Base>
