---
import Base from '../../../layouts/Base.astro';
import { LANGS, type Lang, SCHEDULE, teamName, flagUrl } from '../../../data/tournament';
import { UI } from '../../../i18n/ui';
import { homeUrl, groupsUrl, teamUrl, roundName, roundUrl, koMatchUrl, spainDateLabel, spainTime } from '../../../lib/site';
import { resolveBracket } from '../../../lib/bracket';
import { phaseInfo } from '../../../lib/phase';
import RESULTS from '../../../data/results.json';

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}
const lang = Astro.params.lang as Lang;
const ui = UI[lang];
const byPair = ((RESULTS as any).byPair || {}) as Record<string, any>;
const B = resolveBracket(byPair, lang);
const KO = Object.fromEntries(SCHEDULE.knockout.map((k) => [k.matchNo, k]));

const updatedAt = (RESULTS as any).updatedAt
  ? new Intl.DateTimeFormat(lang === 'en' ? 'en-GB' : lang === 'pt' ? 'pt-BR' : 'es-ES', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit', timeZone: 'Europe/Madrid' }).format(new Date((RESULTS as any).updatedAt))
  : null;
const anyResult = Object.values(byPair).some((r: any) => r && (r.scores || r.live));
const groupStageDone = phaseInfo(byPair).groupStageDone;

const C = {
  es: {
    title: 'Cuadro del Mundial 2026 en directo — de dieciseisavos a la final',
    desc: groupStageDone
      ? 'El cuadro completo de las eliminatorias del Mundial 2026, ya con las 32 selecciones clasificadas: dieciseisavos, octavos, cuartos, semifinales y final. Cruces, horarios y resultados en directo.'
      : 'El cuadro de las eliminatorias del Mundial 2026 que se rellena solo con los resultados reales: dieciseisavos, octavos, cuartos, semifinales y final. Cruces y horarios.',
    h1: 'Cuadro del Mundial 2026',
    intro: groupStageDone
      ? 'El cuadro completo de las eliminatorias del Mundial 2026, ya con las 32 selecciones clasificadas. Los dieciseisavos están en juego y cada ronda se actualiza en directo.'
      : 'El cuadro completo de la fase eliminatoria. Se rellena automáticamente con los equipos reales según avanzan los grupos y se juegan las rondas. Hasta entonces verás de dónde sale cada plaza (1.º A, 2.º B, mejor 3.º…).',
    upd: 'actualizado', live: 'en directo', pen: 'pen.', match: 'P',
  },
  en: {
    title: '2026 World Cup bracket — live knockout stage (round of 32 to final)',
    desc: groupStageDone
      ? 'The complete 2026 World Cup knockout bracket, with all 32 qualified teams: round of 32, round of 16, quarter-finals, semi-finals and final. Fixtures, times and live results.'
      : 'The 2026 World Cup knockout bracket that fills automatically with real results: round of 32, round of 16, quarter-finals, semi-finals and final. Fixtures and times.',
    h1: '2026 World Cup bracket',
    intro: groupStageDone
      ? 'The complete 2026 World Cup knockout bracket, now with all 32 qualified teams. The round of 32 is under way and every round updates live.'
      : 'The full knockout bracket. It fills automatically with the real teams as the groups progress and the rounds are played. Until then you can see where each spot comes from (1st A, 2nd B, best 3rd…).',
    upd: 'updated', live: 'live', pen: 'pens', match: 'M',
  },
  pt: {
    title: 'Chaveamento da Copa 2026 — mata-mata ao vivo (16-avos à final)',
    desc: groupStageDone
      ? 'O chaveamento completo do mata-mata da Copa 2026, já com as 32 seleções classificadas: 16-avos, oitavas, quartas, semis e final. Confrontos, horários e resultados ao vivo.'
      : 'O chaveamento do mata-mata da Copa 2026 que se preenche sozinho com os resultados reais: 16-avos, oitavas, quartas, semis e final. Confrontos e horários.',
    h1: 'Chaveamento da Copa 2026',
    intro: groupStageDone
      ? 'O chaveamento completo do mata-mata da Copa 2026, já com as 32 seleções classificadas. Os 16-avos estão em jogo e cada rodada se atualiza ao vivo.'
      : 'O chaveamento completo da fase eliminatória. Preenche-se automaticamente com as seleções reais conforme os grupos avançam e as rodadas são jogadas. Até lá você vê de onde sai cada vaga (1.º A, 2.º B, melhor 3.º…).',
    upd: 'atualizado', live: 'ao vivo', pen: 'pên.', match: 'P',
  },
}[lang];

const site = (Astro.site?.href ?? 'https://mundialsimulador.com/').replace(/\/$/, '');
const breadcrumbs = [
  { name: ui.nav.home, url: homeUrl(lang) },
  { name: C.h1, url: `/${lang}/cuadro/` },
];

const sideScore = (mm: { a: any; b: any }) => {
  const r = mm.a.code && mm.b.code ? byPair[[mm.a.code, mm.b.code].sort().join('-')] : null;
  return r || null;
};
---
<Base lang={lang} title={C.title} description={C.desc} path="cuadro/" active="bracket" breadcrumbs={breadcrumbs}>
  <div class="page-head"><h1>{C.h1}</h1><p>{C.intro}</p></div>
  {anyResult && updatedAt && <p class="cal-badge">🟢 {C.live} · {C.upd} {updatedAt}h</p>}

  {B.rounds.map((rd) => (
    <section class="bk-round">
      <h2 class="section-h"><a href={roundUrl(lang, rd.round)} style="color:inherit">{roundName(lang, rd.round)} →</a></h2>
      <div class="bk-grid">
        {rd.matches.map((mm) => {
          const ko = KO[mm.m];
          const r = sideScore(mm);
          const sa = r?.scores && mm.a.code ? r.scores[mm.a.code] : null;
          const sb = r?.scores && mm.b.code ? r.scores[mm.b.code] : null;
          const hasScore = sa !== null && sa !== undefined && sb !== null && sb !== undefined;
          const pens = hasScore && sa === sb && mm.winner;
          return (
            <div class={`bk-card${r?.live ? ' live' : ''}`}>
              <div class="bk-top">
                <a href={koMatchUrl(lang, mm.m)} style="color:var(--accent)">{C.match}{mm.m}</a>
                {ko && <span>{spainDateLabel(ko.koSpain, ko.date, lang)}{ko.koSpain ? ` · ${spainTime(ko.koSpain)}h` : ''}</span>}
              </div>
              {[mm.a, mm.b].map((side, i) => {
                const sc = i === 0 ? sa : sb;
                const isWin = mm.winner && side.code === mm.winner;
                return (
                  <div class={`bk-side${isWin ? ' win' : ''}`}>
                    {side.code ? (
                      <a href={teamUrl(lang, side.code)}>
                        <img class="flag" width="23" height="16" loading="lazy" src={flagUrl(side.code)} alt="" />
                        <span class="bk-name">{teamName(side.code, lang)}</span>
                      </a>
                    ) : (
                      <span class="bk-seed">{side.label}</span>
                    )}
                    {hasScore && <b class="bk-sc">{sc}</b>}
                  </div>
                );
              })}
              {pens && <div class="bk-pen">{C.pen}</div>}
            </div>
          );
        })}
      </div>
    </section>
  ))}

  <p style="text-align:center;margin-top:26px">
    <a class="btn primary lg" href={`/${lang}/clasificados/`}>{lang === 'en' ? 'Who qualifies' : lang === 'pt' ? 'Quem se classifica' : 'Quién se clasifica'}</a>
  </p>
</Base>

<style>
  .bk-round { margin-bottom: 6px; }
  .bk-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(248px,1fr)); gap:11px; margin-bottom:18px; }
  .bk-card { background:linear-gradient(180deg,var(--card),var(--bg2)); border:1px solid var(--line); border-radius:12px; padding:9px 11px; }
  .bk-card.live { border-color:#ff5a5a55; }
  .bk-top { display:flex; justify-content:space-between; gap:8px; font-size:11.5px; color:var(--muted2); margin-bottom:7px; }
  .bk-side { display:flex; align-items:center; gap:8px; padding:5px 2px; }
  .bk-side + .bk-side { border-top:1px solid var(--line); }
  .bk-side a { display:flex; align-items:center; gap:8px; color:inherit; flex:1; min-width:0; }
  .bk-name { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; font-size:14.5px; font-weight:600; }
  .bk-seed { flex:1; min-width:0; color:var(--muted2); font-size:13px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  .bk-side.win .bk-name { color:var(--green); }
  .bk-sc { font-weight:800; font-size:15px; }
  .bk-side.win .bk-sc { color:var(--green); }
  .bk-pen { text-align:right; font-size:11px; color:var(--muted2); margin-top:2px; }
</style>
